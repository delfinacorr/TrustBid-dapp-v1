# ─── Servidor ───────────────────────────────────────────────────────────────
# Puerto local del servidor (Render lo sobreescribe automáticamente)
PORT=3001
NODE_ENV=development

# ─── Base de Datos (Neon PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─── Autenticación Neon Auth ───────────────────────────────────────────────
# URL del proyecto Neon con sufijo JWKS para validar las firmas
NEON_AUTH_JWKS_URL=https://nauth-tu-projecto.auth.neon.tech/.well-known/jwks.json

# ─── CORS ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Render — configurar estas en el Dashboard, no aquí ─────────────────────
# RENDER_EXTERNAL_URL=https://trustbid-backend.onrender.com
