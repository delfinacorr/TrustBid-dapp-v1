NEXT_PUBLIC_TRUSTBID_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Accessly web accessibility widget
# Required: set to your project API key to enable the widget on all pages (including /login and /register)
# Unset or leave empty to disable the widget entirely (e.g. in CI / test environments)
NEXT_PUBLIC_ACCESSLY_API_KEY=your_accessly_api_key_here
# Optional: override the CDN URL if you self-host the Accessly script
NEXT_PUBLIC_ACCESSLY_SCRIPT_URL=https://cdn.accessly.io/widget.js
