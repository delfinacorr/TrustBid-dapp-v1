    "@typechain/hardhat": "^9.0.0",
    "hardhat": "^2.19.0",
    "ethers": "^6.0.0",
    "typechain": "^8.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.0"
  }
